# Copy this file to .env and fill in your values
# Never commit .env to git

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string

# Admin (super admin) credentials
ADMIN_EMAIL=lincolnmotiwac@gmail.com
ADMIN_PASSWORD=Admin@Tronic2024!

# Database file location (defaults to tronic_pos.db in project folder)
# On Render.com with a disk: DATABASE_PATH=/mnt/data/tronic_pos.db
DATABASE_PATH=tronic_pos.db

# Server port (Render sets this automatically)
PORT=5000

# ── Firebase Realtime Database sync (optional) ───────────────────────────────
# Leave blank to run without Firebase (SQLite-only mode)
# Get the service account key from:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then paste the entire JSON content (single line) into FIREBASE_CREDENTIALS_JSON:
FIREBASE_CREDENTIALS_JSON=
# OR point to a JSON file:
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Database URL (already hardcoded as default, only override if different project):
FIREBASE_DATABASE_URL=https://bhini-6fd48-default-rtdb.firebaseio.com
